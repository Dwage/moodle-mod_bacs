<div id="view-task-dynamics" class="bacs-view">
    <div class="form-group mb-3 d-flex align-items-center justify-content-center">
        <label for="task-dynamics-select" class="me-2">{{#str}} select_task, mod_bacs {{/str}}:</label>
        <select id="task-dynamics-select" class="form-select w-auto">
            <option value="0" disabled>{{#str}} select_task_placeholder, mod_bacs {{/str}}</option>
            <option value="-1">All Tasks</option>
            {{#tasks_for_template}}
                <option value="{{task_id}}">{{task_order}}. {{name}}</option>
            {{/tasks_for_template}}
        </select>
    </div>

    <div id="task-stats-info" class="text-center mb-3" style="font-size: 1.1em;"></div>

    <canvas id="task-dynamics-chart" style="max-height: 600px;" class="d-none"></canvas>
    
    <div id="task-dynamics-placeholder" class="chart-placeholder">
        <h3>{{#str}} view_taskdynamics, mod_bacs {{/str}}</h3>
        <p class="text-muted">{{#str}} chart_select_task_prompt, mod_bacs {{/str}}</p>
    </div>

    <div id="task-click-details" class="mt-4" style="display: none; background: #fff; padding: 15px; border-radius: 8px; border: 1px solid #dee2e6;">
        <h5 class="mb-3" id="task-details-title" style="color: #333;"></h5>
        <div class="table-responsive">
            <table class="table table-sm table-hover" id="task-details-table">
                <thead class="table-light">
                    <tr>
                        <th>Time</th>
                        <th>User</th>
                        <th>Task</th>
                        <th>Verdict</th>
                        <th>Points</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>